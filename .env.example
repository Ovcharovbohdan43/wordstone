# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Option A (recommended for this API route): service_role JWT — server-only, never NEXT_PUBLIC
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Option B: public anon or publishable key — run supabase/waitlist.sql so RLS allows anon INSERT
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Resend — confirmation email after waitlist signup (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxx
# Sender must match a verified domain in production. Test: onboarding@resend.dev often only delivers TO the same email you use for your Resend account (or use a verified domain + noreply@yourdomain.com).
RESEND_FROM=Wordstone <onboarding@resend.dev>
# Optional: replies go here (support@...)
# RESEND_REPLY_TO=

# Public app URL used to build unsubscribe links in emails
NEXT_PUBLIC_APP_URL=https://wordstone.space
# Secret for HMAC unsubscribe token verification (required in production)
UNSUBSCRIBE_SECRET=change-this-long-random-secret
